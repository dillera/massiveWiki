# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
PORT=3200

# Public base URL — required when running behind a reverse proxy at a subpath.
# This is used for OAuth redirects (Supabase) and should match the URL visitors use.
# Example (subpath):  BASE_URL=https://apps.example.com/wiki
# Example (root):     BASE_URL=https://wiki.example.com
# Leave unset for local dev (falls back to window.location.origin in the browser).
BASE_URL=

# Session secret for the local admin session cookie.
# Generate a strong value with: openssl rand -hex 32
# If unset, a random secret is generated at startup (sessions reset on each restart).
SESSION_SECRET=your-random-secret-here
